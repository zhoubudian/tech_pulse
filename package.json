{
  "name": "tech-pulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scaffold": "next dev --turbo",
    "crawl": "node --env-file .env --import tsx scrapers/index.ts",
    "summarize": "node --env-file .env --import tsx scripts/summarize.ts",
    "crawl:select": "node --env-file .env --import tsx scripts/crawl-select.ts",
    "chat": "node --env-file .env --import tsx scripts/chat.ts",
    "update:select": "npm run crawl:select & npm run summarize",
    "pipeline": "npm run crawl && npm run summarize"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
