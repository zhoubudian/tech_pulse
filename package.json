    "algoliasearch": "^5.50.1",
    "axios": "1.14.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
